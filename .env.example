# ComfyUI endpoint
COMFYUI_BASE_URL=http://127.0.0.1:8188

# Workflow and output paths (absolute or relative to repo root)
COMFYUI_WORKFLOW_PATH=./image_workflow.json
AI_IMAGE_OUTPUT_DIR=./assets/generated

# Polling behavior
AI_IMAGE_TIMEOUT_MS=60000
AI_IMAGE_POLL_INTERVAL_MS=800

# Optional behavior flags
# Set to 0 to disable automatic copy into caller workspace/assets/generated
AI_IMAGE_AUTO_COPY_TO_WORKSPACE=1
# Set to 0 to force outputPath to remain inside this repo
AI_IMAGE_ALLOW_EXTERNAL_OUTPUT=1
